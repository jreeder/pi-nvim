{
  "name": "pi-nvim",
  "version": "0.2.1",
  "description": "Bridge between pi coding agent and Neovim",
  "keywords": [
    "pi-package",
    "pi-extension"
  ],
  "files": [
    "extension.ts",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./extension.ts"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/carderne/pi-nvim.git"
  },
  "author": "Chris Arderne <chris@rdrn.me>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/carderne/pi-nvim/issues"
  },
  "homepage": "https://github.com/carderne/pi-nvim",
  "scripts": {
    "fmt": "oxfmt extension.ts",
    "lint": "oxlint index.ts",
    "check": "tsc --noEmit",
    "ci:fmt": "oxfmt --check extension.ts",
    "ci:lint": "npm run lint",
    "ci:check": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.61.0"
  },
  "peerDependenciesMeta": {
    "@mariozechner/pi-coding-agent": {
      "optional": true
    }
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.61.0",
    "@types/node": "^24",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5"
  }
}
